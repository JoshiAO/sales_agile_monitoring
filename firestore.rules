rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isSuperuser() {
      return signedIn() && myRole() == 'superuser';
    }

    function isSupervisor() {
      return signedIn() && myRole() == 'supervisor';
    }

    function isOwnedAgileDoc(docId) {
      return signedIn() && docId.matches('^.+_' + request.auth.uid + '$');
    }

    match /users/{userId} {
      allow read: if signedIn() && (
        request.auth.uid == userId ||
        isSuperuser() ||
        (isSupervisor() && resource.data.supervisorId == request.auth.uid)
      );
      allow update: if signedIn() && (request.auth.uid == userId || isSuperuser());
      allow create, delete: if isSuperuser();
    }

    match /routes/{routeId} {
      allow create: if signedIn();
      allow read: if signedIn() && (
        isSuperuser() ||
        resource.data.salesmanId == request.auth.uid ||
        resource.data.supervisorId == request.auth.uid
      );
      allow update: if signedIn() && (
        isSuperuser() ||
        resource.data.salesmanId == request.auth.uid ||
        resource.data.supervisorId == request.auth.uid
      );
      allow delete: if isSuperuser();
    }

    match /agile_targets/{targetId} {
      allow read: if signedIn() && (
        isSuperuser() ||
        isOwnedAgileDoc(targetId) ||
        (resource != null && resource.data.supervisorId == request.auth.uid)
      );

      allow create, update: if signedIn() && (
        isSuperuser() ||
        (isSupervisor() && request.resource.data.supervisorId == request.auth.uid)
      );

      allow delete: if isSuperuser();
    }

    match /agile_submissions/{submissionId} {
      allow read: if signedIn() && (
        isSuperuser() ||
        isOwnedAgileDoc(submissionId) ||
        (resource != null && resource.data.supervisorId == request.auth.uid)
      );

      allow create, update: if signedIn() && (
        isSuperuser() ||
        request.resource.data.salesmanId == request.auth.uid
      );

      allow delete: if isSuperuser();
    }
  }
}
